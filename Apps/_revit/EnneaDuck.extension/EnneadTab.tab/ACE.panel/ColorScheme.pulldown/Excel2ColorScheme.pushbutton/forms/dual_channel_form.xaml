<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Excel2ColorScheme &#8212; Office Template (Dual Channel)"
        Height="720" Width="960"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        MinHeight="600" MinWidth="780"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}"
        FontFamily="RomanD">

    <Window.Resources>
        <SolidColorBrush x:Key="TextColor" Color="#FFDAE8FD"/>
        <SolidColorBrush x:Key="AccentColor" Color="#f39c12"/>
        <SolidColorBrush x:Key="PanelColor" Color="#FF464646"/>
        <SolidColorBrush x:Key="PanelColorDeep" Color="#FF2E2E2E"/>
        <SolidColorBrush x:Key="MutedTextColor" Color="#FFCBCBCB"/>
        <SolidColorBrush x:Key="DimTextColor" Color="#FF9A9A9A"/>

        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
        </Style>

        <Style TargetType="{x:Type Button}">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Background" Value="{StaticResource TextColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource PanelColor}"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0,10,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Margin="3"
                                Height="25"
                                SnapsToDevicePixels="true">
                            <ContentPresenter Name="Presenter"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              RecognizesAccessKey="True"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentColor}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SmallButton" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="6,0,6,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8" Margin="2" Height="20">
                            <ContentPresenter
                                Margin="{TemplateBinding Padding}"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentColor}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource AccentColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,0,16,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="12" Margin="4" Height="34">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFFFB84D"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LinkButton" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource AccentColor}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <TextBlock Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   TextDecorations="Underline"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#FFFFB84D"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="{x:Type ComboBox}">
            <Setter Property="Height" Value="24"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="6,0,6,0"/>
        </Style>

        <Style TargetType="{x:Type TextBox}">
            <Setter Property="Background" Value="#FF3A3A3A"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="BorderBrush" Value="#FF5A5A5A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,3,6,3"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style TargetType="{x:Type CheckBox}">
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="{x:Type Separator}">
            <Setter Property="Background" Value="#FF5A5A5A"/>
            <Setter Property="Height" Value="1"/>
        </Style>

        <!-- Glow storyboard for the Apply button when ready -->
        <Storyboard x:Key="ApplyGlow" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0.85" To="1.0" Duration="0:0:1.0"/>
        </Storyboard>
    </Window.Resources>

    <Border BorderThickness="1" CornerRadius="15" Margin="20" Name="main_border"
            MouseLeftButtonDown="mouse_down_main_panel">
        <Border.Background>
            <SolidColorBrush Color="#FF464646" Opacity="1"/>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect Color="#FFFFE59C" BlurRadius="15" Opacity="0.8"/>
        </Border.Effect>

        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- Title bar -->
                <RowDefinition Height="*"/>      <!-- Main content -->
                <RowDefinition Height="Auto"/>   <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- ===== TITLE BAR ===== -->
            <Grid Grid.Row="0" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Excel2ColorScheme &#8212; Office Template (Dual Channel)"
                           Foreground="#FFFFE59C" FontSize="16" FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="&#10005;" Click="CloseButton_Click"
                        Width="28" Background="Transparent"
                        Foreground="{StaticResource MutedTextColor}"/>
            </Grid>

            <!-- ===== MAIN CONTENT: two-column ===== -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT SIDEBAR -->
                <Border Grid.Column="0" Background="{StaticResource PanelColorDeep}"
                        CornerRadius="8" Padding="12" Margin="0,0,8,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Excel File" FontWeight="Bold" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="ExcelPathBox" Grid.Column="0" IsReadOnly="True"
                                         VerticalContentAlignment="Center"/>
                                <Button x:Name="BrowseExcelButton" Grid.Column="1" Content="Browse&#8230;"
                                        Width="72" Margin="6,0,0,0" Click="BrowseExcelButton_Click"/>
                            </Grid>

                            <TextBlock Text="Worksheet" FontWeight="Bold" Margin="0,0,0,4"/>
                            <ComboBox x:Name="WorksheetCombo" Margin="0,0,0,14"
                                      SelectionChanged="WorksheetCombo_SelectionChanged"/>

                            <!-- DEPARTMENT block (red stripe) -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <Border Width="12" Height="12" Background="#C66" Margin="0,0,6,0" CornerRadius="2"/>
                                <TextBlock Text="Department" FontWeight="Bold" Foreground="#FFDD8888"/>
                            </StackPanel>
                            <ComboBox x:Name="DeptSchemeCombo" Margin="0,0,0,4"
                                      SelectionChanged="DeptSchemeCombo_SelectionChanged"/>
                            <TextBlock Text="Parameter" FontSize="11"
                                       Foreground="{StaticResource DimTextColor}" Margin="0,2,0,2"/>
                            <TextBox x:Name="DeptParameterBox" Margin="0,0,0,14"
                                     TextChanged="DeptParameterBox_TextChanged"/>

                            <!-- PROGRAM block (blue stripe) -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <Border Width="12" Height="12" Background="#48A" Margin="0,0,6,0" CornerRadius="2"/>
                                <TextBlock Text="Program" FontWeight="Bold" Foreground="#FF88AADD"/>
                            </StackPanel>
                            <ComboBox x:Name="ProgSchemeCombo" Margin="0,0,0,4"
                                      SelectionChanged="ProgSchemeCombo_SelectionChanged"/>
                            <TextBlock Text="Parameter" FontSize="11"
                                       Foreground="{StaticResource DimTextColor}" Margin="0,2,0,2"/>
                            <TextBox x:Name="ProgParameterBox" Margin="0,0,0,14"
                                     TextChanged="ProgParameterBox_TextChanged"/>

                            <Separator Margin="0,8,0,8"/>
                            <Button x:Name="DownloadSampleButton"
                                    Content="&#8595; Download Sample (Dual)"
                                    Style="{StaticResource LinkButton}"
                                    HorizontalAlignment="Left"
                                    Click="DownloadSampleButton_Click"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- RIGHT MAIN AREA: 2 stacked preview panels -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- DEPT preview -->
                    <Border Grid.Row="0" Background="{StaticResource PanelColorDeep}"
                            CornerRadius="8" Margin="0,0,0,6" Padding="10">
                        <Border.BorderBrush>
                            <SolidColorBrush Color="#CC6666"/>
                        </Border.BorderBrush>
                        <Border.BorderThickness>
                            <Thickness Left="3" Top="0" Right="0" Bottom="0"/>
                        </Border.BorderThickness>
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="Department" FontWeight="Bold" Foreground="#FFDD8888"/>
                                <TextBlock Text=" &#183; color table + diff"
                                           Foreground="{StaticResource DimTextColor}"/>
                            </StackPanel>
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                                <Border Background="#FF1E3A1E" Padding="6,2" Margin="0,0,6,0" CornerRadius="3">
                                    <TextBlock x:Name="DeptAddBadge" Text="&#9679; Add 0" FontSize="11"
                                               Foreground="#FF6EC96E"/>
                                </Border>
                                <Border Background="#FF3A2B0A" Padding="6,2" Margin="0,0,6,0" CornerRadius="3">
                                    <TextBlock x:Name="DeptUpdateBadge" Text="&#8635; Update 0" FontSize="11"
                                               Foreground="{StaticResource AccentColor}"/>
                                </Border>
                                <Border Background="#FF3A3A3A" Padding="6,2" Margin="0,0,6,0" CornerRadius="3">
                                    <TextBlock x:Name="DeptUnchangedBadge" Text="&#183; Unchanged 0" FontSize="11"
                                               Foreground="{StaticResource DimTextColor}"/>
                                </Border>
                                <Border Background="#FF3A1A1A" Padding="6,2" Margin="0,0,6,0" CornerRadius="3">
                                    <TextBlock x:Name="DeptOrphanBadge" Text="&#9888; Orphan 0" FontSize="11"
                                               Foreground="#FFCB7070"/>
                                </Border>
                            </StackPanel>
                            <DataGrid x:Name="DeptColorGrid" AutoGenerateColumns="False"
                                      HeadersVisibility="Column" CanUserAddRows="False" IsReadOnly="True"
                                      GridLinesVisibility="Horizontal"
                                      Background="#FF3A3A3A"
                                      Foreground="{StaticResource TextColor}"
                                      BorderThickness="0"
                                      RowBackground="#FF3A3A3A"
                                      AlternatingRowBackground="#FF424242">
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="{x:Type DataGridColumnHeader}">
                                        <Setter Property="Background" Value="#FF2E2E2E"/>
                                        <Setter Property="Foreground" Value="{StaticResource MutedTextColor}"/>
                                        <Setter Property="Padding" Value="6,4"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Entry" Binding="{Binding Name}" Width="2*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
                                                <Setter Property="Padding" Value="4,2"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTemplateColumn Header="Color" Width="80">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Rectangle Width="60" Height="18" Fill="{Binding Brush}"
                                                           Stroke="#FF5A5A5A" StrokeThickness="0.5"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Hex" Binding="{Binding Hex}" Width="100">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource MutedTextColor}"/>
                                                <Setter Property="Padding" Value="4,2"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="100">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource AccentColor}"/>
                                                <Setter Property="Padding" Value="4,2"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>

                    <!-- PROGRAM preview -->
                    <Border Grid.Row="1" Background="{StaticResource PanelColorDeep}"
                            CornerRadius="8" Padding="10">
                        <Border.BorderBrush>
                            <SolidColorBrush Color="#4488AA"/>
                        </Border.BorderBrush>
                        <Border.BorderThickness>
                            <Thickness Left="3" Top="0" Right="0" Bottom="0"/>
                        </Border.BorderThickness>
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="Program" FontWeight="Bold" Foreground="#FF88AADD"/>
                                <TextBlock Text=" &#183; color table + diff"
                                           Foreground="{StaticResource DimTextColor}"/>
                            </StackPanel>
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                                <Border Background="#FF1E3A1E" Padding="6,2" Margin="0,0,6,0" CornerRadius="3">
                                    <TextBlock x:Name="ProgAddBadge" Text="&#9679; Add 0" FontSize="11"
                                               Foreground="#FF6EC96E"/>
                                </Border>
                                <Border Background="#FF3A2B0A" Padding="6,2" Margin="0,0,6,0" CornerRadius="3">
                                    <TextBlock x:Name="ProgUpdateBadge" Text="&#8635; Update 0" FontSize="11"
                                               Foreground="{StaticResource AccentColor}"/>
                                </Border>
                                <Border Background="#FF3A3A3A" Padding="6,2" Margin="0,0,6,0" CornerRadius="3">
                                    <TextBlock x:Name="ProgUnchangedBadge" Text="&#183; Unchanged 0" FontSize="11"
                                               Foreground="{StaticResource DimTextColor}"/>
                                </Border>
                                <Border Background="#FF3A1A1A" Padding="6,2" Margin="0,0,6,0" CornerRadius="3">
                                    <TextBlock x:Name="ProgOrphanBadge" Text="&#9888; Orphan 0" FontSize="11"
                                               Foreground="#FFCB7070"/>
                                </Border>
                            </StackPanel>
                            <DataGrid x:Name="ProgColorGrid" AutoGenerateColumns="False"
                                      HeadersVisibility="Column" CanUserAddRows="False" IsReadOnly="True"
                                      GridLinesVisibility="Horizontal"
                                      Background="#FF3A3A3A"
                                      Foreground="{StaticResource TextColor}"
                                      BorderThickness="0"
                                      RowBackground="#FF3A3A3A"
                                      AlternatingRowBackground="#FF424242">
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="{x:Type DataGridColumnHeader}">
                                        <Setter Property="Background" Value="#FF2E2E2E"/>
                                        <Setter Property="Foreground" Value="{StaticResource MutedTextColor}"/>
                                        <Setter Property="Padding" Value="6,4"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Entry" Binding="{Binding Name}" Width="2*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
                                                <Setter Property="Padding" Value="4,2"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTemplateColumn Header="Color" Width="80">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Rectangle Width="60" Height="18" Fill="{Binding Brush}"
                                                           Stroke="#FF5A5A5A" StrokeThickness="0.5"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Hex" Binding="{Binding Hex}" Width="100">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource MutedTextColor}"/>
                                                <Setter Property="Padding" Value="4,2"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="100">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource AccentColor}"/>
                                                <Setter Property="Padding" Value="4,2"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>
                </Grid>
            </Grid>

            <!-- ===== FOOTER ===== -->
            <Border Grid.Row="2" Background="{StaticResource PanelColorDeep}"
                    CornerRadius="8" Padding="12,8" Margin="0,10,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" x:Name="StatusText"
                               Text="&#9889; Both schemes apply in one Revit transaction"
                               Foreground="{StaticResource DimTextColor}"
                               VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="CancelButton" Content="Cancel" Width="90" Margin="0,0,8,0"
                                Click="CancelButton_Click"/>
                        <Button x:Name="ApplyButton" Content="Apply Both"
                                Style="{StaticResource PrimaryButton}"
                                Width="120" IsEnabled="False"
                                Click="ApplyButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
