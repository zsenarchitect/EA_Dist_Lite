<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="460"
        Title="EnneadTab"
        Foreground="#000"
        Margin="0"
        SizeToContent="WidthAndHeight"
        ShowInTaskbar="True"
        BorderThickness="0"
        Background="{x:Null}"
        WindowStartupLocation="CenterScreen"
        ScrollViewer.VerticalScrollBarVisibility="Disabled"
        HorizontalContentAlignment="Center"
        UseLayoutRounding="False"
        FontFamily="RomanD"
        AllowsTransparency="True"
        WindowStyle="None"
        MouseLeftButtonDown="mouse_down_main_panel"
        Cursor="ScrollAll">
    <Window.Resources>
        <SolidColorBrush x:Key="AboutWindowTextColor" Color="#FFDAE8FD"/>
        <SolidColorBrush x:Key="AboutWindowHightlightColor" Color="#f39c12"/>
        <SolidColorBrush x:Key="AboutWindowMainPanelColor" Color="#FF464646"/>
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground"
                    Value="{StaticResource AboutWindowTextColor}"/>
        </Style>
        <Style TargetType="{x:Type GroupBox}">
            <Setter Property="Foreground"
                    Value="{StaticResource AboutWindowTextColor}"/>
        </Style>
        <Style TargetType="{x:Type Button}">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Background" Value="{StaticResource AboutWindowTextColor}"/>
            <Setter Property="BorderBrush" Value="#cccccc"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource AboutWindowMainPanelColor}"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0,10,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Margin="5"
                                Height="24"
                                SnapsToDevicePixels="true">
                            <ContentPresenter Name="Presenter"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              RecognizesAccessKey="True"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AboutWindowHightlightColor}" />
                                <Setter Property="BorderBrush" Value="{StaticResource AboutWindowHightlightColor}" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="{x:Type TextBox}">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,0,8,0"/>
            <Setter Property="Height" Value="22"/>
            <Style.Resources>
                <Style TargetType="{x:Type Border}">
                    <Setter Property="CornerRadius" Value="8" />
                </Style>
            </Style.Resources>
        </Style>
    </Window.Resources>
    <Border BorderThickness="1"
            CornerRadius="15"
            Margin="20,20,20,20">
        <Border.Background>
            <SolidColorBrush Color="#FF464646" Opacity="1"/>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect Color="#FF53D0F1" BlurRadius="15" Opacity="0.5"/>
        </Border.Effect>
        <Grid Margin="20,20,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Image Grid.Column="0"
                   Height="100"
                   x:Name="logo_img"
                   VerticalAlignment="Bottom"
                   HorizontalAlignment="Left" />

            <StackPanel Margin="0, 20, 0, 0"
                        Grid.Column="1">
                <TextBlock x:Name="title_text" Text="Finish Floor by Room" Foreground="#FFDB6AF5" FontSize="20" TextWrapping="Wrap" FontWeight="Bold" />
                <TextBlock x:Name="sub_text"
                           Text="Pick rooms, choose a floor type and a level offset, then create finish floors."
                           Foreground="#FFCBCBCB"
                           TextWrapping="Wrap"
                           MaxWidth="360"
                           HorizontalAlignment="Left"/>

                <Separator/>

                <GroupBox Header="Floor Type" Margin="0,10,0,0">
                    <ComboBox x:Name="combo_floor_type"
                              Margin="5,5,5,5"
                              Height="24"
                              IsEditable="False"/>
                </GroupBox>

                <GroupBox Header="Level Offset" Margin="0,10,0,0">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="mm:" VerticalAlignment="Center" Margin="5,0,5,0"/>
                            <TextBox Grid.Column="1" x:Name="textbox_offset_mm" Text="0.0" Margin="5,0,10,0" LostFocus="offset_mm_lost_focus"/>
                            <TextBlock Grid.Column="2" Text="inch:" VerticalAlignment="Center" Margin="5,0,5,0"/>
                            <TextBox Grid.Column="3" x:Name="textbox_offset_inch" Text="0.000" Margin="5,0,5,0" LostFocus="offset_inch_lost_focus"/>
                        </Grid>
                        <TextBlock Text="Top of floor, relative to each room's level. The room's own base offset is added automatically."
                                   Foreground="#FF9AA0A6"
                                   FontSize="10"
                                   TextWrapping="Wrap"
                                   Margin="5,4,5,0"/>
                    </StackPanel>
                </GroupBox>

                <TextBlock x:Name="debug_textbox" Text="No rooms picked yet. Click 'Pick Rooms'." Foreground="#FFCBCBCB" TextWrapping="Wrap" Margin="0,10,0,0"/>

                <WrapPanel HorizontalAlignment="Center" Margin="0,10,0,0">
                    <Button Content="Pick Rooms" Click="pick_rooms_click" x:Name="bt_pick_rooms" Width="120"/>
                    <Button Content="Create Floors By Rooms" Click="create_click" x:Name="bt_create" Width="180" Margin="10,0,0,0"/>
                    <Button Content="Close" Click="close_click" Width="80" Margin="10,0,0,0"/>
                </WrapPanel>

            </StackPanel>
        </Grid>
    </Border>
</Window>
