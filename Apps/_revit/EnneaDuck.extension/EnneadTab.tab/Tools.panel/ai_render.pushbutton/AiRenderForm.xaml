<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EnneaDuck: View Render"
        Foreground="#000"
        Margin="0"
        Width="1100" MinWidth="900"
        Height="980" MinHeight="760"
        MaxHeight="1120"
        ShowInTaskbar="True"
        BorderThickness="0"
        Background="{x:Null}"
        WindowStartupLocation="CenterScreen"
        HorizontalContentAlignment="Center"
        UseLayoutRounding="False"
        FontFamily="RomanD"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="CanResize"
        Cursor="Arrow">
    <Window.Resources>
        <SolidColorBrush x:Key="TextColor" Color="#FFDAE8FD"/>
        <SolidColorBrush x:Key="AccentColor" Color="#f39c12"/>
        <SolidColorBrush x:Key="PanelColor" Color="#FF464646"/>
        <SolidColorBrush x:Key="PanelColorDeep" Color="#FF2E2E2E"/>
        <SolidColorBrush x:Key="MutedTextColor" Color="#FFCBCBCB"/>
        <SolidColorBrush x:Key="DimTextColor" Color="#FF9A9A9A"/>

        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
        </Style>

        <Style TargetType="{x:Type Button}">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Background" Value="{StaticResource TextColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource PanelColor}"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0,10,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Margin="3"
                                Height="25"
                                SnapsToDevicePixels="true">
                            <ContentPresenter Name="Presenter"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              RecognizesAccessKey="True"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentColor}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Small button style for inline prompt actions / per-row actions -->
        <Style x:Key="SmallButton" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="6,0,6,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8" Margin="2" Height="20">
                            <ContentPresenter
                                Margin="{TemplateBinding Padding}"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentColor}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary (accent) button style for the Queue Render CTA -->
        <Style x:Key="PrimaryButton" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource AccentColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,0,16,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="12" Margin="4" Height="34">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFFFB84D"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Hyperlink-style text button for "Open ennead-ai.com →" -->
        <Style x:Key="LinkButton" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource AccentColor}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <TextBlock Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   TextDecorations="Underline"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#FFFFB84D"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ComboBox dark-theme styling (minimal) -->
        <Style TargetType="{x:Type ComboBox}">
            <Setter Property="Height" Value="24"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="6,0,6,0"/>
        </Style>

        <!-- TextBox dark-theme styling -->
        <Style TargetType="{x:Type TextBox}">
            <Setter Property="Background" Value="#FF3A3A3A"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="BorderBrush" Value="#FF5A5A5A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,3,6,3"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="SpellCheck.IsEnabled" Value="True"/>
            <!-- Language is set by code-behind to avoid parse issues when default IME is missing -->
        </Style>

        <Style TargetType="{x:Type CheckBox}">
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="{x:Type Separator}">
            <Setter Property="Background" Value="#FF5A5A5A"/>
            <Setter Property="Height" Value="1"/>
        </Style>

        <!-- ============== GALLERY ROW TEMPLATES (small / large thumbnail) ==============
             Two keyed DataTemplates for the gallery ListView. The "Large" toggle in the
             filter bar swaps lv_gallery.ItemTemplate between these via FindResource in
             toggle_large_thumbs_Changed (code-behind). GalleryRowSmall is the default
             (thumbnails 84x60); GalleryRowLarge doubles them to 168x120 and gives the
             info/status columns more room. Every binding + Click handler is identical
             between the two so no code-behind handler depends on which is active. -->
        <DataTemplate x:Key="GalleryRowSmall">
            <Grid Margin="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="92"/>   <!-- original -->
                    <ColumnDefinition Width="92"/>   <!-- result -->
                    <ColumnDefinition Width="*"/>    <!-- info -->
                    <ColumnDefinition Width="150"/>  <!-- status/timer -->
                    <ColumnDefinition Width="150"/>  <!-- inline Save + Copy + More -->
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#FF222222" Width="84" Height="60">
                    <Image Source="{Binding OriginalThumb}" Stretch="UniformToFill"
                           MouseLeftButtonUp="row_view_original_Click"/>
                </Border>
                <Border Grid.Column="1" Background="#FF222222" Width="84" Height="60">
                    <Grid>
                        <Image Source="{Binding ResultThumb}" Stretch="UniformToFill"
                               MouseLeftButtonUp="row_view_result_Click"/>
                        <TextBlock Text="{Binding KindIcon}"
                                   HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                   Margin="0,0,3,1" FontSize="14"
                                   Foreground="White"/>
                    </Grid>
                </Border>
                <Grid Grid.Column="2" Margin="8,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="{Binding StyleName}" FontWeight="Bold" FontSize="12"/>
                    <TextBlock Grid.Row="1" Text="{Binding PromptPreview}"
                               Foreground="{StaticResource MutedTextColor}"
                               FontSize="11" TextWrapping="Wrap"
                               MaxHeight="30" TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Top" Margin="0,2,0,0"/>
                    <TextBlock Grid.Row="2" Text="{Binding Subtitle}"
                               Foreground="{StaticResource DimTextColor}"
                               FontSize="10" VerticalAlignment="Bottom"/>
                </Grid>
                <StackPanel Grid.Column="3" VerticalAlignment="Bottom">
                    <TextBlock Text="{Binding StatusText}" FontSize="11" FontWeight="Bold"
                               Foreground="{Binding StatusColor}"/>
                    <ProgressBar Visibility="{Binding ProgressVisibility}"
                                 Value="{Binding ProgressPct}" Maximum="100"
                                 Height="6" Margin="0,2,8,0"
                                 IsIndeterminate="{Binding ProgressIndeterminate}"/>
                </StackPanel>
                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Style="{StaticResource SmallButton}"
                            Content="Save" FontSize="10" Width="44"
                            ToolTip="Save result to disk"
                            Visibility="{Binding SaveVisibility}"
                            Click="row_save_Click"/>
                    <Button Style="{StaticResource SmallButton}"
                            Content="Copy" FontSize="10" Width="44"
                            ToolTip="Copy image to clipboard"
                            Visibility="{Binding SaveVisibility}"
                            Click="row_copy_Click"/>
                    <Button Style="{StaticResource SmallButton}"
                            Content="More" FontSize="10" Width="44"
                            ToolTip="More actions: Show prompt, Re-run, Animate, Open in Studio, Delete..."
                            Click="row_more_Click"/>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="GalleryRowLarge">
            <Grid Margin="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="176"/>  <!-- original -->
                    <ColumnDefinition Width="176"/>  <!-- result -->
                    <ColumnDefinition Width="*"/>    <!-- info -->
                    <ColumnDefinition Width="150"/>  <!-- status/timer -->
                    <ColumnDefinition Width="150"/>  <!-- inline Save + Copy + More -->
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#FF222222" Width="168" Height="120">
                    <Image Source="{Binding OriginalThumb}" Stretch="UniformToFill"
                           MouseLeftButtonUp="row_view_original_Click"/>
                </Border>
                <Border Grid.Column="1" Background="#FF222222" Width="168" Height="120">
                    <Grid>
                        <Image Source="{Binding ResultThumb}" Stretch="UniformToFill"
                               MouseLeftButtonUp="row_view_result_Click"/>
                        <TextBlock Text="{Binding KindIcon}"
                                   HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                   Margin="0,0,4,2" FontSize="18"
                                   Foreground="White"/>
                    </Grid>
                </Border>
                <Grid Grid.Column="2" Margin="8,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="{Binding StyleName}" FontWeight="Bold" FontSize="13"/>
                    <TextBlock Grid.Row="1" Text="{Binding PromptPreview}"
                               Foreground="{StaticResource MutedTextColor}"
                               FontSize="11" TextWrapping="Wrap"
                               MaxHeight="72" TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Top" Margin="0,2,0,0"/>
                    <TextBlock Grid.Row="2" Text="{Binding Subtitle}"
                               Foreground="{StaticResource DimTextColor}"
                               FontSize="10" VerticalAlignment="Bottom"/>
                </Grid>
                <StackPanel Grid.Column="3" VerticalAlignment="Bottom">
                    <TextBlock Text="{Binding StatusText}" FontSize="11" FontWeight="Bold"
                               Foreground="{Binding StatusColor}"/>
                    <ProgressBar Visibility="{Binding ProgressVisibility}"
                                 Value="{Binding ProgressPct}" Maximum="100"
                                 Height="6" Margin="0,2,8,0"
                                 IsIndeterminate="{Binding ProgressIndeterminate}"/>
                </StackPanel>
                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Style="{StaticResource SmallButton}"
                            Content="Save" FontSize="10" Width="44"
                            ToolTip="Save result to disk"
                            Visibility="{Binding SaveVisibility}"
                            Click="row_save_Click"/>
                    <Button Style="{StaticResource SmallButton}"
                            Content="Copy" FontSize="10" Width="44"
                            ToolTip="Copy image to clipboard"
                            Visibility="{Binding SaveVisibility}"
                            Click="row_copy_Click"/>
                    <Button Style="{StaticResource SmallButton}"
                            Content="More" FontSize="10" Width="44"
                            ToolTip="More actions: Show prompt, Re-run, Animate, Open in Studio, Delete..."
                            Click="row_more_Click"/>
                </StackPanel>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Border BorderThickness="1" CornerRadius="15" Margin="20" Name="main_border"
            MouseLeftButtonDown="mouse_down_main_panel">
        <Border.Background>
            <SolidColorBrush Color="#FF464646" Opacity="1"/>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect Color="#FFFFE59C" BlurRadius="15" Opacity="0.8"/>
        </Border.Effect>

        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Header -->
                <RowDefinition Height="Auto"/>  <!-- Auth banner (Item A 2026-04-30) -->
                <RowDefinition Height="Auto"/>  <!-- Controls -->
                <RowDefinition Height="Auto"/>  <!-- Separator -->
                <RowDefinition Height="*"/>     <!-- Gallery (fills remaining) -->
                <RowDefinition Height="Auto"/>  <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- ============== HEADER ============== -->
            <Grid Grid.Row="0" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Image Grid.Column="0" x:Name="logo_img" Height="40"
                       VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0,0,12,0"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="title_text" Text="EnneaDuck: View Render"
                               Foreground="#FFFFE59C" FontSize="18" FontWeight="Bold"/>
                    <TextBlock x:Name="sub_text"
                               Text="Render Revit views through Ennead's curated style library."
                               Foreground="{StaticResource MutedTextColor}"
                               TextWrapping="Wrap" FontSize="11"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource LinkButton}" Content="Open ennead-ai.com &gt;"
                            Click="open_web_Click" Margin="0,0,12,0"/>
                    <!-- Sign out / switch account (2026-06-04): placed by the ennead-ai.com
                         link per user preference. -->
                    <Button x:Name="sign_out_button" Style="{StaticResource LinkButton}"
                            Content="Sign out" Click="sign_out_Click" Margin="0,0,12,0"
                            ToolTip="Sign out and clear the cached login, then sign in again to switch account (e.g. if the gallery shows the wrong/empty history)."/>
                    <!-- 2026-06-04: explicit text "Close" button. The prior ✕ glyph
                         rendered as an unrecognizable sliver under the window's RomanD
                         font ("missing close button"); a text label reads clearly and
                         RomanD renders letters fine. -->
                    <Button Content="Close" Click="close_Click" ToolTip="Close this window"
                            Width="64" Height="28" FontSize="12" FontWeight="Bold"
                            Background="#33FFFFFF" Foreground="#FFEDEDED"/>
                </StackPanel>
            </Grid>

            <!-- ============== AUTH BANNER (Item A, 2026-04-30) ============== -->
            <!-- Hidden by default. Shown when AUTH.get_token() is None.
                 Self-dismisses via DispatcherTimer polling (1s) once OAuth
                 callback writes the token. Always uses AUTH.request_auth()
                 for the sign-in click; never webbrowser.open() a static URL
                 (the URL needs a per-call ?port=NNNNN query, generated at
                 request_auth() time). -->
            <Border Grid.Row="1" x:Name="auth_banner" Visibility="Collapsed"
                    Background="#FF3A2E14" CornerRadius="6" Padding="12,10"
                    Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock x:Name="auth_heading" Text="Sign in to EnneaDuck"
                               Foreground="#FFE0B070" FontWeight="Bold" FontSize="13"/>
                    <TextBlock x:Name="auth_body"
                               Text="AI Render uses your Ennead account. Click below to sign in."
                               Foreground="{StaticResource MutedTextColor}"
                               TextWrapping="Wrap" FontSize="11" Margin="0,4,0,0"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Button x:Name="auth_button" Content="Sign in"
                                Click="auth_signin_Click" Padding="14,4"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ============== CONTROLS (two-column: capture thumb + prompt stack) ============== -->
            <Grid Grid.Row="2" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="420"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT: Capture thumb + update button + resolution/aspect + style ref -->
                <!-- 2026-04-30: column 280 -> 420, preview 168h -> 300h. User
                     feedback: enlarge capture preview, shrink prompt area. -->
                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock x:Name="preview_label" Text="Click Update Capture to begin"
                               Foreground="{StaticResource MutedTextColor}"
                               FontSize="11" Margin="0,0,0,4"/>
                    <Border Background="#FF2A2A2A" CornerRadius="6" Padding="4" Height="300">
                        <Image x:Name="capture_preview" Stretch="Uniform"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Button Content="Update Capture" Click="capture_Click" Margin="0,6,0,0"/>

                    <TextBlock Text="Capture Resolution" FontSize="11" Margin="0,10,0,2"
                               Foreground="{StaticResource MutedTextColor}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0" x:Name="cb_resolution" Margin="0,0,4,0"/>
                        <ComboBox Grid.Column="1" x:Name="cb_aspect" Margin="4,0,0,0"/>
                    </Grid>
                    <TextBlock x:Name="resolution_hint" Text="1500 x 844 (High, 16:9)"
                               FontSize="10" Margin="0,2,0,0"
                               Foreground="{StaticResource DimTextColor}"/>

                    <TextBlock Text="Style Reference (optional)" FontSize="11" Margin="0,12,0,4"
                               Foreground="{StaticResource MutedTextColor}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Vertical">
                            <Button Style="{StaticResource SmallButton}"
                                    Content="Browse..." Click="browse_style_Click"/>
                            <Button Style="{StaticResource SmallButton}"
                                    Content="Paste Clipboard" Click="paste_style_Click"/>
                            <Button Style="{StaticResource SmallButton}"
                                    Content="Load from Library..." Click="library_style_Click"/>
                            <Button Style="{StaticResource SmallButton}" x:Name="bt_clear_style"
                                    Content="Clear" Click="clear_style_Click" Visibility="Collapsed"/>
                        </StackPanel>
                        <Border Grid.Column="1" Background="#FF2A2A2A" CornerRadius="4"
                                Width="120" Height="92" Margin="8,0,0,0">
                            <Image x:Name="style_preview" Stretch="Uniform" MouseLeftButtonUp="style_preview_Click"/>
                        </Border>
                    </Grid>
                </StackPanel>

                <!-- RIGHT: Style dropdowns + prompt + action row -->
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Rendering Style" FontSize="11" Margin="0,0,0,4"
                               Foreground="{StaticResource MutedTextColor}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0" x:Name="cb_category" Margin="0,0,4,0"
                                  IsEditable="True" IsTextSearchEnabled="True"
                                  SelectionChanged="category_changed"/>
                        <ComboBox Grid.Column="1" x:Name="cb_style" Margin="4,0,0,0"
                                  IsEditable="True" IsTextSearchEnabled="True"
                                  SelectionChanged="style_changed"/>
                    </Grid>

                    <!-- My Prompts row (saved per-user via /api/prompts/list|save) -->
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="My Prompts:" FontSize="11"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource MutedTextColor}" Margin="0,0,4,0"/>
                        <ComboBox Grid.Column="1" x:Name="cb_my_prompts"
                                  IsEditable="True" IsTextSearchEnabled="True"
                                  SelectionChanged="my_prompt_Changed"/>
                        <Button Grid.Column="2" Style="{StaticResource SmallButton}"
                                x:Name="bt_save_prompt" Content="Save current..."
                                Click="save_prompt_Click" Margin="4,0,0,0"/>
                    </Grid>

                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Prompt" FontSize="11"
                                   Foreground="{StaticResource MutedTextColor}"/>
                        <CheckBox Grid.Column="1" x:Name="cb_interior" Content="Interior scene"
                                  FontSize="10"/>
                    </Grid>
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="tbox_prompt" Height="90"
                                 TextWrapping="Wrap" AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"/>
                        <StackPanel Grid.Column="1" Margin="4,0,0,0">
                            <Button Style="{StaticResource SmallButton}" x:Name="bt_spell"
                                    Content="Spell Check" Click="spell_Click"
                                    ToolTip="Check spelling and grammar"/>
                            <Button Style="{StaticResource SmallButton}" x:Name="bt_lengthen"
                                    Content="Improve Prompt" Click="lengthen_Click"
                                    ToolTip="Use AI to improve your prompt"/>
                            <Button Style="{StaticResource SmallButton}" x:Name="bt_shorten"
                                    Content="Summarize Prompt" Click="shorten_Click"
                                    ToolTip="Use AI to summarize and reduce prompt length (75% of original)"/>
                            <Button Style="{StaticResource SmallButton}" x:Name="bt_reset_prompt"
                                    Content="Clear Prompt" Click="reset_prompt_Click"
                                    ToolTip="Clear the prompt textbox"/>
                            <Button Style="{StaticResource SmallButton}" x:Name="bt_undo_prompt"
                                    Content="Undo" Click="undo_prompt_Click" IsEnabled="False"
                                    ToolTip="Undo the last AI change"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" x:Name="status_label"
                                   Text="Ready. Capture a view then queue a render."
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource MutedTextColor}"
                                   FontSize="11" TextTrimming="CharacterEllipsis"/>
                        <Button Grid.Column="1" Style="{StaticResource PrimaryButton}"
                                x:Name="bt_render" Content="Queue Render  &gt;"
                                Click="render_Click"/>
                    </Grid>
                </StackPanel>
            </Grid>

            <!-- ============== SEPARATOR ============== -->
            <Separator Grid.Row="3" Margin="0,4,0,8"/>

            <!-- ============== GALLERY ============== -->
            <Grid Grid.Row="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- filter bar -->
                    <RowDefinition Height="*"/>     <!-- list -->
                </Grid.RowDefinitions>

                <!-- Filter bar -->
                <Grid Grid.Row="0" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" x:Name="gallery_header"
                               Text="Gallery"
                               FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" x:Name="gallery_count"
                               Text="loading..." Margin="8,0,0,0"
                               FontSize="11" VerticalAlignment="Center"
                               Foreground="{StaticResource MutedTextColor}"/>
                    <!-- 2026-06-04: big/small thumbnail toggle. Swaps lv_gallery.ItemTemplate
                         between GalleryRowSmall (default) and GalleryRowLarge in code-behind
                         (toggle_large_thumbs_Changed). Session-state only (no prefs helper). -->
                    <CheckBox Grid.Column="2" x:Name="cb_large_thumbs" Content="Large"
                              Margin="4,0" VerticalAlignment="Center"
                              Checked="toggle_large_thumbs_Changed"
                              Unchecked="toggle_large_thumbs_Changed"
                              ToolTip="Show larger gallery thumbnails"/>
                    <ComboBox Grid.Column="3" x:Name="cb_date_filter" Width="140"
                              Margin="4,0" VerticalAlignment="Center"
                              SelectionChanged="date_filter_Changed"/>
                    <TextBox Grid.Column="4" x:Name="tbox_search" Width="180" Height="22"
                             Margin="4,0" VerticalAlignment="Center"
                             TextChanged="search_Changed"
                             ToolTip="Search prompt text or view name"/>
                    <Button Grid.Column="5" Style="{StaticResource SmallButton}"
                            Content="⟳ Refresh" Click="refresh_gallery_Click"/>
                    <Button Grid.Column="6" Style="{StaticResource SmallButton}"
                            x:Name="bt_active_jobs" Content="Active jobs (0)"
                            Click="scroll_to_active_Click"/>
                </Grid>

                <!-- Resume button shown only when worker pauses on 401 -->
                <Border Grid.Row="0" HorizontalAlignment="Right" Margin="0,28,0,0"
                        x:Name="resume_panel" Visibility="Collapsed"
                        Background="#FF8B0000" CornerRadius="6" Padding="6,2,6,2">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠ Queue paused (auth)" Foreground="White"
                                   FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Button Style="{StaticResource SmallButton}"
                                Content="Resume" Click="resume_Click"/>
                    </StackPanel>
                </Border>

                <!-- Gallery list (virtualized). MinHeight floors the row so the
                     tall left capture column can't starve the history list to a
                     sliver (2026-06-04: user reported "cannot see history lists"
                     — the gallery *-row was collapsing under the controls at
                     default window height). -->
                <Border Grid.Row="1" Background="#FF2A2A2A" CornerRadius="6" MinHeight="280">
                    <ListView x:Name="lv_gallery" Background="Transparent" BorderThickness="0"
                              ItemTemplate="{StaticResource GalleryRowSmall}"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              VirtualizingStackPanel.IsVirtualizing="True"
                              VirtualizingStackPanel.VirtualizationMode="Recycling">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,1"/>
                                <Setter Property="Background" Value="#FF333333"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#FF3F3F3F"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>
                    </ListView>
                </Border>
            </Grid>

            <!-- ============== FOOTER ============== -->
            <Grid Grid.Row="5" Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <CheckBox Grid.Column="0" x:Name="cb_auto_save" Content="Auto-save to Cloud"
                          IsChecked="True" Checked="auto_save_Changed" Unchecked="auto_save_Changed"
                          VerticalAlignment="Center"
                          ToolTip="Saves every new render to your cloud Gallery (visible from web Studio, Revit, Rhino, mobile). Applies to newly-queued renders only - in-flight jobs keep their setting. Turn OFF to keep this render local-only (won't appear on other devices)."/>
                <TextBlock Grid.Column="1" x:Name="cache_size_label"
                           Text="-"
                           Margin="12,0,0,0" VerticalAlignment="Center"
                           FontSize="11" Foreground="{StaticResource DimTextColor}"
                           Cursor="Hand"
                           ToolTip="Click to manage local gallery cache (clearing is safe - cloud copy is canonical)"
                           MouseLeftButtonUp="cache_label_Click"/>
                <Button Grid.Column="2" Style="{StaticResource SmallButton}"
                        Content="Open Output Folder" Click="open_folder_Click"/>
                <TextBlock Grid.Column="3" x:Name="quota_label"
                           Text="Quota: -" Margin="12,0,0,0" VerticalAlignment="Center"
                           FontSize="11" Foreground="{StaticResource DimTextColor}"
                           ToolTip="Office-wide daily render quota"/>
                <!-- Build stamp (2026-06-04): visible so a stale loaded copy is obvious. -->
                <TextBlock Grid.Column="4" x:Name="build_label"
                           Text="build -" Margin="12,0,0,0" VerticalAlignment="Center"
                           FontSize="10" Foreground="{StaticResource DimTextColor}"
                           ToolTip="Build timestamp of the running ai_render_script.py. If this looks old, Revit is loading a stale copy."/>
            </Grid>
        </Grid>
    </Border>
</Window>
